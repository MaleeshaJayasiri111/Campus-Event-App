@page "/ViewEvents"
@using CampusEventAdmin.Models
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary">Campus Events</h3>
        <button class="btn btn-success shadow-sm" @onclick='() => Nav.NavigateTo("/ManageEvents")'>+ Add New</button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-success shadow-sm border-0 mb-4">
            <strong>✔ @statusMessage</strong>
        </div>
    }

    @if (showConfirmDelete)
    {
        <div class="alert alert-danger shadow-sm border-0 mb-4 p-3 text-center">
            <p class="fw-bold mb-2">Are you sure you want to delete this event?</p>
            <button class="btn btn-danger btn-sm px-4 me-2" @onclick="ConfirmDelete">Yes, Delete</button>
            <button class="btn btn-secondary btn-sm px-4" @onclick="CancelDelete">No</button>
        </div>
    }

    @if (events == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading...</p>
        </div>
    }
    else if (!events.Any())
    {
        <div class="alert alert-info shadow-sm border-0">
            No events found. Start by adding one!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in events)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div style="height: 200px; background: #eee;">
                            @if (!string.IsNullOrEmpty(item.poster))
                            {
                                <img src="@item.poster" class="w-100 h-100" style="object-fit: cover;" />
                            }
                        </div>
                        <div class="card-body">
                            <h5 class="fw-bold">@item.title</h5>
                            <p class="small text-muted mb-3">@item.location | @item.date</p>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-primary btn-sm w-100" @onclick='() => Nav.NavigateTo($"/ManageEvents/{item.id}")'>Edit</button>
                                <button class="btn btn-outline-danger btn-sm w-100" @onclick="() => PromptDelete(item.id)">Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Event>? events;
    private bool showConfirmDelete = false;
    private string? selectedId;
    private string statusMessage = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await LoadData(); }
    }

    private async Task LoadData()
    {
        try
        {
            var user = await JS.InvokeAsync<object>("firebaseAuth.getUser");
            if (user == null) { Nav.NavigateTo("/", true); return; }
            events = await JS.InvokeAsync<List<Event>>("firebaseInterop.GetEvents");
            StateHasChanged();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private void PromptDelete(string id)
    {
        statusMessage = "";
        selectedId = id;
        showConfirmDelete = true;
    }

    private void CancelDelete()
    {
        showConfirmDelete = false;
        selectedId = null;
    }

    private async Task ConfirmDelete()
    {
        if (string.IsNullOrEmpty(selectedId)) return;
        try
        {
            await JS.InvokeVoidAsync("firebaseInterop.DeleteEvent", selectedId);
            showConfirmDelete = false;
            statusMessage = "Event deleted successfully!";
            await LoadData();
            StateHasChanged();
            await Task.Delay(3000);
            statusMessage = "";
            StateHasChanged();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }
}