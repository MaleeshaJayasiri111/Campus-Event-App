@using CampusEventAdmin.Models
@page "/ViewFeedbacks"
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Student Feedbacks</h2>
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/Home")'>Back to Dashboard</button>
    </div>

    @if (feedbacks == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading feedbacks...</p>
        </div>
    }
    else if (!feedbacks.Any())
    {
        <div class="alert alert-info shadow-sm">
            <i class="bi bi-info-circle me-2"></i> No feedbacks submitted yet.
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Student Name</th>
                            <th>Event Name</th>
                            <th>Feedback</th>
                            <th class="text-center">Rating</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fb in feedbacks)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@fb.submittedBy</div>
                                    <small class="text-muted">@fb.email</small>
                                </td>
                                <td><span class="badge bg-info text-dark">@fb.eventTitle</span></td>
                                <td style="max-width: 300px; white-space: normal;">
                                    @fb.comment
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-warning text-dark px-3 py-2">
                                        <i class="bi bi-star-fill me-1"></i> @fb.rating / 5
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<FeedbackViewModel>? feedbacks;

    public class FeedbackViewModel : Feedbacks
    {
        public string id { get; set; } = "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadFeedbacks();
        }
    }

    private async Task LoadFeedbacks()
    {
        var user = await JS.InvokeAsync<object>("firebaseAuth.getUser");
        if (user == null)
        {
            Nav.NavigateTo("/", true);
            return;
        }

        try
        {
            feedbacks = await JS.InvokeAsync<List<FeedbackViewModel>>("firebaseInterop.GetFeedbacks");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error: " + ex.Message);
        }
    }
}